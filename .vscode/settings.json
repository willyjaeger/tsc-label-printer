{
  "python.defaultInterpreterPath": "python",
  "editor.formatOnSave": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.exclude": {
    "**/__pycache__": true,
    "build/": true,
    "dist/": true,
    "*.spec": true
  },
  "[html]": {
    "editor.tabSize": 2
  },
  "livePreview.serverPort": 5050,
  "terminal.integrated.defaultProfile.windows": "Git Bash"
}
